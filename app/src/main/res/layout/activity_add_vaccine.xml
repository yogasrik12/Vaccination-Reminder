<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F3EF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:background="#1B5E20"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add / Update Vaccine"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- PATIENT LIST -->
            <ListView
                android:id="@+id/listPatients"
                android:layout_width="match_parent"
                android:layout_height="150dp"/>

            <!-- RECORD LIST -->
            <ListView
                android:id="@+id/listRecords"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="10dp"/>

            <!-- INPUTS -->
            <EditText
                android:id="@+id/editVaccineName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Vaccine Name"/>

            <EditText
                android:id="@+id/editVaccineType"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Vaccine Type"/>

            <EditText
                android:id="@+id/editTakenDate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Taken Date"/>

            <EditText
                android:id="@+id/editDueDate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Due Date"/>

            <EditText
                android:id="@+id/editNotes"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Notes"/>

            <!-- SAVE -->
            <Button
                android:id="@+id/btnSaveRecord"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Save Record"
                android:backgroundTint="#1B5E20"
                android:textColor="#FFFFFF"/>

            <!-- UPDATE -->
            <Button
                android:id="@+id/btnUpdateRecord1"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Update Record"
                android:layout_marginTop="10dp"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"/>

            <!-- DELETE -->
            <Button
                android:id="@+id/btnDeleteRecord"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Delete Record"
                android:layout_marginTop="10dp"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>