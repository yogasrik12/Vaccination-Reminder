<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ================= HEADER ================= -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="@drawable/bg_login_header">

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="40dp"
                android:background="@drawable/circle_bg"
                android:padding="16dp"
                android:src="@drawable/login"
                android:scaleType="fitCenter" />


            <TextView

                android:id="@+id/txtWelcome"
                android:layout_below="@id/imgProfile"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="Welcome Back!"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <TextView
                android:id="@+id/txtSub"
                android:layout_below="@id/txtWelcome"
                android:layout_centerHorizontal="true"
                android:text="Sign in to your account"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

        </RelativeLayout>

        <!-- ================= BODY ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40dp"
            android:background="@drawable/bg_login_body"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Session Box -->
            <LinearLayout
                android:id="@+id/sessionBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_session_box"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_lock_lock"/>

                <TextView
                    android:layout_marginStart="10dp"
                    android:text="Session saved after login via SharedPreferences"
                    android:textColor="#1B8A6B"
                    android:textSize="13sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
            </LinearLayout>

            <!-- Username -->
            <TextView
                android:text="Username"
                android:layout_marginTop="18dp"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:hint="Enter Username"/>

            <!-- Password -->
            <TextView
                android:text="Password"
                android:layout_marginTop="12dp"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:inputType="textPassword"
                android:hint="Enter Password"/>

            <!-- Forgot -->
            <TextView
                android:id="@+id/txtForgot"
                android:text="Forgot Password?"
                android:textColor="#1A73E8"
                android:textStyle="bold"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <!-- Sign In -->
            <Button
                android:id="@+id/btnSignIn"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="18dp"
                android:text="Sign In →"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:backgroundTint="#1A73E8"/>

            <!-- OR Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="1dp"
                    android:background="#CCCCCC"/>

                <TextView
                    android:text=" OR "
                    android:textColor="#888888"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <View
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="1dp"
                    android:background="#CCCCCC"/>
            </LinearLayout>

            <!-- Doctor Login -->
            <Button
                android:id="@+id/btnDoctor"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:text="👨‍⚕️ Login as Doctor"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:backgroundTint="#2E7D32"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>